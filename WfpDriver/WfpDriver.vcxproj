  <Target Name="TestSignDriver" AfterTargets="Link">
    <PropertyGroup>
      <_CertFile>$(ProjectDir)WfpTestCert.cer</_CertFile>
      <_PfxFile>$(ProjectDir)WfpTestCert.pfx</_PfxFile>
      <_SignTool>$(SignToolPath)\signtool.exe</_SignTool>
      <_MakeCert>$(SignToolPath)\makecert.exe</_MakeCert>
      <_Pvk2Pfx>$(SignToolPath)\pvk2pfx.exe</_Pvk2Pfx>
      <_DriverOutput>$(OutDir)$(TargetName)$(TargetExt)</_DriverOutput>
    </PropertyGroup>
    <Exec Condition="!Exists('$(_PfxFile)')"
          Command="&quot;$(_MakeCert)&quot; -r -pe -ss PrivateCertStore -n &quot;CN=WfpTestCert&quot; -sv &quot;$(ProjectDir)WfpTestCert.pvk&quot; &quot;$(_CertFile)&quot;"
          IgnoreExitCode="true" />
    <Exec Condition="!Exists('$(_PfxFile)')"
          Command="&quot;$(_Pvk2Pfx)&quot; -pvk &quot;$(ProjectDir)WfpTestCert.pvk&quot; -spc &quot;$(_CertFile)&quot; -pfx &quot;$(_PfxFile)&quot;" />
    <Exec Command="&quot;$(_SignTool)&quot; sign /fd SHA256 /f &quot;$(_PfxFile)&quot; &quot;$(_DriverOutput)&quot;" />
    <Message Text="[TestSign] Driver signed: $(_DriverOutput)" Importance="high" />
  </Target>
